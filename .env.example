# ===========================================
# Ahead AI — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Never commit .env to git.

# --- Stripe ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Webhook URL: https://<your-domain>/api/webhook
# Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Database (PostgreSQL) ---
# For local dev: postgresql://user:password@localhost:5432/aheadai
# For Railway: set automatically via Railway Postgres service
DATABASE_URL=postgresql://user:password@localhost:5432/aheadai

# Public DB URL — used by Prisma at build time on Railway (TCP proxy)
# Only needed in Railway env vars, not for local dev
# DATABASE_PUBLIC_URL=postgresql://user:password@host:port/railway

# --- Email (SMTP) ---
# SMTP server credentials for sending purchase confirmation emails
# Without these, emails are logged to console but not sent
SMTP_HOST=mikal.ovh
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Sender address (From header in outgoing emails)
EMAIL_FROM=noreply@synairo.com

# --- App ---
# Your app's public URL (used in download links and emails)
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron (email retry) ---
# Secret to protect /api/cron/check-emails endpoint
# Set any random string; cron caller must send: Authorization: Bearer <this-value>
CRON_SECRET=your-random-cron-secret
